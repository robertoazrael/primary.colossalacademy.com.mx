---
import SectionIntro from "./SectionIntro.astro";

interface Pillar {
  title: string;
  subtitle: string;
  description: string;
  points: string[];
}

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  pillars: Pillar[];
}

const { eyebrow, title, description, pillars } = Astro.props;
---

<section class="section-spacing">
  <div class="container space-y-10">
    <SectionIntro eyebrow={eyebrow} title={title} description={description} center />
    <div class="grid gap-6 lg:grid-cols-3">
      {
        pillars.map((pillar) => (
          <article class="feature-card h-full">
            <p class="eyebrow">{pillar.subtitle}</p>
            <h3 class="mt-3 text-2xl font-bold text-slate-900">{pillar.title}</h3>
            <p class="mt-4 leading-7 text-slate-600">{pillar.description}</p>
            <ul class="mt-6 space-y-3 text-sm leading-6 text-slate-600">
              {pillar.points.map((point) => (
                <li class="flex gap-3">
                  <span class="mt-2 h-2.5 w-2.5 rounded-full bg-[color:var(--color-accent)]"></span>
                  <span>{point}</span>
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
