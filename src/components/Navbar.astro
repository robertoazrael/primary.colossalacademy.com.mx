---
const { currentPath = "/" } = Astro.props;

const links = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/approach", label: "Approach" },
  { href: "/gifted-learning", label: "Gifted Learning" },
  { href: "/activities", label: "Activities" },
  { href: "/admissions", label: "Admissions" },
  { href: "/contact", label: "Contact" }
];

const isActive = (href) => currentPath === href;
---

<header class="site-header">
  <div class="container flex flex-col gap-4 py-4 md:flex-row md:items-center md:justify-between">
    <a href="/" class="brand-mark" aria-label="Primary Colossal Academy home">
      <span class="brand-mark__icon" aria-hidden="true"></span>
      <span>
        <span class="brand-mark__title">Colossal Academy</span>
        <span class="brand-mark__subtitle">Primary Campus</span>
      </span>
    </a>

    <nav aria-label="Primary">
      <ul class="flex flex-wrap items-center justify-start gap-2 text-sm font-semibold text-slate-700 md:justify-end">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  "nav-link",
                  isActive(link.href) && "nav-link-active"
                ]}
                aria-current={isActive(link.href) ? "page" : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
