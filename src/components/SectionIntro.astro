---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  center?: boolean;
}

const { eyebrow, title, description, center = false } = Astro.props;
---

<div class:list={["space-y-4", center && "mx-auto max-w-3xl text-center"]}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 class="text-3xl font-extrabold tracking-tight text-slate-900 md:text-4xl">{title}</h2>
  {description && <p class="text-lg leading-8 text-slate-600">{description}</p>}
</div>
