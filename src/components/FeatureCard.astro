---
interface Props {
  title: string;
  description: string;
  tone?: "default" | "highlight";
}

const { title, description, tone = "default" } = Astro.props;
---

<article class:list={["feature-card", tone === "highlight" && "feature-card-highlight"]}>
  <h3 class="text-xl font-bold text-slate-900">{title}</h3>
  <p class="mt-3 leading-7 text-slate-600">{description}</p>
</article>
