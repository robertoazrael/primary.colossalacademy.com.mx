---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import SectionIntro from "../components/SectionIntro.astro";

const contactCards = [
  {
    title: "Admissions questions",
    description:
      "Share your child’s age, educational background, and what kind of learning environment you are hoping to find."
  },
  {
    title: "Campus visits",
    description:
      "Private visits and family conversations can be arranged by appointment."
  },
  {
    title: "Location details",
    description:
      "A map and full address can be added here once final campus information is confirmed."
  }
];
---

<BaseLayout
  title="Contact | Primary Colossal Academy"
  description="Contact Primary Colossal Academy to request information, schedule a conversation, or inquire about admissions."
  currentPath="/contact"
>
  <Hero
    eyebrow="Contact"
    title="We welcome thoughtful questions from"
    highlight="families exploring the school."
    description="If you would like to learn more about Primary Colossal Academy, we invite you to get in touch. We are happy to answer questions about our program, gifted learning support, and admissions."
    primaryCta={{ href: "#inquiry-form", label: "Send an inquiry" }}
    secondaryCta={{ href: "/admissions", label: "See admissions" }}
    imageSrc="/images/admissions-welcome.svg"
    imageAlt="Illustrated school contact and welcome scene"
  />

  <section class="section-spacing pt-8">
    <div class="container grid gap-8 lg:grid-cols-[0.8fr_1.2fr]">
      <div class="space-y-6">
        <SectionIntro
          eyebrow="Get in touch"
          title="Start with a conversation"
          description="This contact page uses placeholder information for now. Replace the details below once final admissions and campus contacts are ready."
        />
        <div class="grid gap-4">
          {contactCards.map((item) => (
            <article class="feature-card">
              <h3 class="text-xl font-bold text-slate-900">{item.title}</h3>
              <p class="mt-3 leading-7 text-slate-600">{item.description}</p>
            </article>
          ))}
        </div>
      </div>

      <div id="inquiry-form" class="feature-card feature-card-highlight">
        <p class="eyebrow">Inquiry form placeholder</p>
        <h2 class="mt-3 text-3xl font-extrabold text-slate-900">Tell us about your family</h2>
        <p class="mt-4 max-w-2xl leading-7 text-slate-600">
          This static form can be connected to a Netlify form or another submission service later.
        </p>
        <form class="mt-8 grid gap-5 md:grid-cols-2" name="contact" method="post" data-netlify="true">
          <input type="hidden" name="form-name" value="contact" />

          <label class="form-field">
            <span>Parent or guardian name</span>
            <input type="text" name="name" placeholder="Your name" />
          </label>

          <label class="form-field">
            <span>Email address</span>
            <input type="email" name="email" placeholder="you@example.com" />
          </label>

          <label class="form-field">
            <span>Student age</span>
            <input type="text" name="student-age" placeholder="Age or grade" />
          </label>

          <label class="form-field">
            <span>Phone number</span>
            <input type="tel" name="phone" placeholder="+52 ..." />
          </label>

          <label class="form-field md:col-span-2">
            <span>What are you looking for in a school?</span>
            <textarea name="message" rows="6" placeholder="Tell us about your child and what matters to your family."></textarea>
          </label>

          <div class="md:col-span-2">
            <button type="submit" class="btn-primary">Send inquiry</button>
          </div>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
