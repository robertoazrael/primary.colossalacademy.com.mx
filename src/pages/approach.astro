---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTASection from "../components/CTASection.astro";
import FeatureCard from "../components/FeatureCard.astro";
import Hero from "../components/Hero.astro";
import SectionIntro from "../components/SectionIntro.astro";
import ThreePillarSection from "../components/ThreePillarSection.astro";
import expertGuidancePhoto from "../assets/school/primary/colossal-expert-guidance.webp";

const foundations = [
  {
    title: "Student voice and choice",
    description:
      "Children have meaningful opportunities to help shape topics, questions, products, and next steps within a well-designed framework."
  },
  {
    title: "Rigorous academic guidance",
    description:
      "Teachers protect coherence and standards, making sure student ownership is paired with clear academic outcomes."
  },
  {
    title: "Reflection and revision",
    description:
      "Students learn to evaluate their work, respond to feedback, and improve quality over time."
  }
];

const modelCards = [
  {
    title: "Start with strong questions",
    description:
      "Units are framed around meaningful ideas that invite children to connect knowledge, evidence, and imagination."
  },
  {
    title: "Offer purposeful pathways",
    description:
      "Students may investigate through discussion, writing, design, research, models, experiments, or presentations."
  },
  {
    title: "Differentiate with intention",
    description:
      "Teachers adapt challenge, support, grouping, and pacing to meet learners where they are without flattening expectations."
  },
  {
    title: "Build durable habits",
    description:
      "Planning, collaboration, self-management, and communication are taught directly as part of the learning process."
  },
  {
    title: "Use tools responsibly",
    description:
      "Technology supports research, creation, and communication when appropriate, always under thoughtful adult guidance."
  },
  {
    title: "Make learning visible",
    description:
      "Children share work, explain thinking, and see their own growth through feedback, documentation, and celebration."
  }
];

const pillars = [
  {
    subtitle: "Teacher role",
    title: "Designer, mentor, and guide",
    description:
      "Teachers remain central. They establish rigor, coach thinking, and know when to scaffold, stretch, or step back.",
    points: [
      "Designs standards-based learning sequences",
      "Mentors children through challenge and reflection",
      "Protects both depth and emotional safety"
    ]
  },
  {
    subtitle: "Student role",
    title: "Engaged learner with growing agency",
    description:
      "Students contribute ideas, make choices, and take on greater responsibility as their confidence and maturity grow.",
    points: [
      "Practices ownership in age-appropriate ways",
      "Learns to ask, plan, revise, and present",
      "Develops self-knowledge as a learner"
    ]
  },
  {
    subtitle: "Environment role",
    title: "Structure that supports possibility",
    description:
      "The classroom environment is calm, rich, and intentionally prepared so children can think deeply and work independently.",
    points: [
      "Clear routines and strong culture",
      "Resources that invite inquiry and making",
      "Flexible spaces for focus and collaboration"
    ]
  }
];
---

<BaseLayout
  title="Approach | Primary Colossal Academy"
  description="A closer look at the educational approach of Primary Colossal Academy, including inquiry, student ownership, and guided differentiation."
  currentPath="/approach"
>
  <Hero
    eyebrow="Our approach"
    title="A primary model centered on"
    highlight="agency, inquiry, and expert guidance."
    description="At Primary Colossal Academy, children are active participants in their learning. They are invited to think, question, choose, create, and reflect within a structure designed by skilled educators."
    primaryCta={{ href: "/admissions", label: "Explore admissions" }}
    secondaryCta={{ href: "/contact", label: "Talk with our team" }}
    imageSrc={expertGuidancePhoto.src}
    imageAlt="Teacher offering expert guidance to students at Colossal Academy Primary"
  />

  <section class="section-spacing pt-8">
    <div class="container space-y-10">
      <SectionIntro
        eyebrow="What this means"
        title="Personalized learning without losing clarity or rigor"
        description="We reinterpret student agency for a primary school context: children have meaningful ownership, while teachers maintain coherence, care, and strong academic direction."
      />
      <div class="grid gap-6 md:grid-cols-3">
        {foundations.map((item) => <FeatureCard {...item} />)}
      </div>
    </div>
  </section>

  <ThreePillarSection
    eyebrow="How it works"
    title="Three elements working together"
    description="This model depends on children, teachers, and the learning environment each playing a deliberate role."
    pillars={pillars}
  />

  <section class="section-spacing bg-white">
    <div class="container space-y-10">
      <SectionIntro
        eyebrow="In practice"
        title="What learning looks like day to day"
        description="The approach becomes real through consistent classroom habits, carefully designed projects, and responsive teaching."
      />
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {modelCards.map((item) => <FeatureCard {...item} />)}
      </div>
    </div>
  </section>

  <CTASection
    title="Families often ask what makes this approach different."
    description="The difference is that students are not passive recipients of instruction. They are guided into becoming thoughtful, capable participants in their own learning."
    primaryCta={{ href: "/admissions", label: "Start admissions" }}
    secondaryCta={{ href: "/contact", label: "Ask a question" }}
  />
</BaseLayout>
