---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTASection from "../components/CTASection.astro";
import Hero from "../components/Hero.astro";
import artPhoto from "../assets/school/primary/colossal-kids-at-art.webp";
import expertGuidancePhoto from "../assets/school/primary/colossal-expert-guidance.webp";
import labPhoto from "../assets/school/primary/colossal-kids-at-lab.webp";
---

<BaseLayout
  title="Approach | Primary Colossal Academy"
  description="A closer look at the educational approach of Primary Colossal Academy, including inquiry, student ownership, and guided differentiation."
  currentPath="/approach"
>
  <Hero
    eyebrow="Our approach"
    title="A primary model centered on"
    highlight="agency, inquiry, and expert guidance."
    description="At Primary Colossal Academy, children are active participants in their learning. They are invited to think, question, choose, create, and reflect within a structure designed by skilled educators."
    primaryCta={{ href: "/admissions", label: "Explore admissions" }}
    secondaryCta={{ href: "/contact", label: "Talk with our team" }}
    imageSrc={expertGuidancePhoto.src}
    imageAlt="Teacher offering expert guidance to students at Colossal Academy Primary"
  />

  <section class="section-spacing pt-8">
    <div class="container grid items-center gap-10 lg:grid-cols-2 lg:gap-14">
      <div class="space-y-5">
        <h2 class="text-3xl font-extrabold tracking-tight text-slate-900 md:text-4xl">Laboratory</h2>
        <div class="space-y-5 text-lg leading-8 text-slate-600">
          <p>
            Our science lab is an AI-powered, hands-on environment where students engage in biology, chemistry, and physics using real tools. They work with microscopes and digital probes, lab glassware and safe reagents, and sensors, microcontrollers, and robotics kits to investigate living systems, chemical reactions, and forces, motion, and energy through interdisciplinary projects.
          </p>
          <p>
            The kind of work we do is best seen through our projects. In an ocean clean-up study, students analyze water samples, test pollutants, and design and program filtration systems. In a project on sustainably feeding the world, they study ecosystems, soil, and energy systems while building automated solutions. This work extends into the atelier, where art becomes a tool for designing, prototyping, and communicating ideas.
          </p>
        </div>
      </div>
      <div class="overflow-hidden rounded-3xl shadow-2xl shadow-slate-900/10">
        <img
          src={labPhoto.src}
          alt="Primary students working with lab tools at Colossal Academy"
          width={labPhoto.width}
          height={labPhoto.height}
          loading="lazy"
          class="aspect-[4/3] h-full w-full object-cover"
        />
      </div>
    </div>
  </section>

  <section class="section-spacing bg-white">
    <div class="container grid items-center gap-10 lg:grid-cols-2 lg:gap-14">
      <div class="overflow-hidden rounded-3xl shadow-2xl shadow-slate-900/10 lg:order-first">
        <img
          src={artPhoto.src}
          alt="Primary students creating artwork in the atelier at Colossal Academy"
          width={artPhoto.width}
          height={artPhoto.height}
          loading="lazy"
          class="aspect-[4/3] h-full w-full object-cover"
        />
      </div>
      <div class="space-y-5">
        <h2 class="text-3xl font-extrabold tracking-tight text-slate-900 md:text-4xl">
          A Reggio Emilia–Inspired Atelier and Arts Program
        </h2>
        <div class="space-y-5 text-lg leading-8 text-slate-600">
          <p>
            Our atelier is a studio for thinking, creating, and self-expression. Students work with high-quality materials in visual arts—including sculpture, painting, and drawing—developing technique, attention to detail, and the ability to express ideas, perspectives, and emotions with clarity. We view art as a fundamental language: a way for children to make sense of the world, communicate meaning, and develop confidence in their own voice.
          </p>
          <p>
            This work is complemented by a strong performing arts program. Students participate in choir, learn instruments as part of a school band, and engage in music theater, combining voice, movement, and storytelling. Across all disciplines, the arts are treated as a serious practice—students create, rehearse, revise, and present work with intention, building both creative expression and disciplined craftsmanship.
          </p>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title="Families often ask what makes this approach different."
    description="The difference is that students are not passive recipients of instruction. They are guided into becoming thoughtful, capable participants in their own learning."
    primaryCta={{ href: "/admissions", label: "Start admissions" }}
    secondaryCta={{ href: "/contact", label: "Ask a question" }}
  />
</BaseLayout>
