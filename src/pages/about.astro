---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTASection from "../components/CTASection.astro";
import founderPhoto from "../assets/school/about/colossal-miss-courtney.webp";
import logoCAMB from "../assets/school/about/colossal-logo-camb.webp";
import logoCHRI from "../assets/school/about/colossal-logo-chri.webp";
import logoCONRICYT from "../assets/school/about/colossal-logo-conricyt.webp";
import logoEton from "../assets/school/about/colossal-logo-eton.jpeg.webp";
import logoGeorgia from "../assets/school/about/colossal-logo-georgia.webp";
import logoLIU from "../assets/school/about/colossal-logo-liu.webp";
import logoMACM from "../assets/school/about/colossal-logo-macm.webp";
import logoROLC from "../assets/school/about/colossal-logo-rolc.webp";
import logoSEP from "../assets/school/about/colossal-logo-sep.webp";
import logoUCF from "../assets/school/about/colossal-logo-ucf.webp";

const founderLogos = [
  { image: logoCAMB, alt: "CAMB logo" },
  { image: logoCHRI, alt: "CHRI logo" },
  { image: logoCONRICYT, alt: "CONRICyT logo" },
  { image: logoEton, alt: "Eton logo" },
  { image: logoGeorgia, alt: "University of Georgia logo" },
  { image: logoLIU, alt: "LIU logo" },
  { image: logoMACM, alt: "MACM logo" },
  { image: logoROLC, alt: "ROLC logo" },
  { image: logoSEP, alt: "SEP logo" },
  { image: logoUCF, alt: "UCF logo" }
];
---

<BaseLayout
  title="About | Primary Colossal Academy"
  description="Learn about the educational leadership behind Colossal Academy and the experience that shaped its vision."
  currentPath="/about"
>
  <section class="relative isolate overflow-hidden bg-[linear-gradient(180deg,#f8f4ea_0%,#fffdf8_46%,#ffffff_100%)]">
    <div class="absolute inset-x-0 top-0 h-32 bg-[radial-gradient(circle_at_top,_rgba(221,184,106,0.22),_transparent_65%)]"></div>
    <div class="container section-spacing grid gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
      <div class="space-y-6">
        <p class="eyebrow">About the founder</p>
        <h1 class="max-w-3xl text-4xl font-extrabold tracking-tight text-slate-900 md:text-5xl">
          Built by an Educator. Designed for Children.
        </h1>
        <div class="max-w-3xl space-y-5 text-lg leading-8 text-slate-700">
          <p>
            Colossal Academy was created from two things: a deep commitment to education, and the
            desire to give my own child the kind of school every child deserves.
          </p>
          <p>
            I have spent my career leading schools, designing curriculum, and working with
            education systems across five continents. I studied at the University of California,
            San Diego, El Colegio de México, Masaryk University, and the Harvard Graduate School
            of Education.
          </p>
          <p>
            My work has been used in over 80 universities, received the Yass Award, and been
            featured in Forbes. I have also spoken at education and AI conferences across the
            United States, Latin America, and the Caribbean.
          </p>
          <p>
            This school brings that experience into something simple: a place where children are
            known, challenged, and prepared for the future.
          </p>
        </div>
      </div>

      <div class="mx-auto w-full max-w-md">
        <div class="overflow-hidden rounded-[2rem] border border-[#d9c6a0] bg-white p-3 shadow-[0_24px_80px_rgba(15,23,42,0.14)]">
          <img
            src={founderPhoto.src}
            alt="Portrait of the founder of Colossal Academy"
            class="aspect-[4/5] w-full rounded-[1.5rem] object-cover object-top"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="section-spacing bg-white pt-8">
    <div class="container space-y-8">
      <div class="max-w-3xl space-y-3">
        <p class="eyebrow">Selected organizations and institutions</p>
        <h2 class="text-3xl font-extrabold tracking-tight text-slate-900 md:text-4xl">
          A body of work shaped across schools, universities, and education systems
        </h2>
        <p class="text-lg leading-8 text-slate-600">
          These organizations reflect part of the professional context behind the vision for
          Colossal Academy.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5">
        {founderLogos.map(({ image, alt }) => (
          <div class="group flex min-h-28 items-center justify-center rounded-3xl border border-slate-200 bg-slate-50/70 px-6 py-5 transition duration-300 hover:-translate-y-1 hover:border-[#cfaa57] hover:bg-white hover:shadow-[0_18px_40px_rgba(15,23,42,0.08)]">
            <img
              src={image.src}
              alt={alt}
              class="max-h-12 w-auto max-w-full object-contain opacity-75 grayscale transition duration-300 group-hover:opacity-100 group-hover:grayscale-0"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title="Interested in whether Primary Colossal Academy is the right fit for your family?"
    description="We welcome thoughtful questions and family conversations about your child, your priorities, and the kind of learning environment you are seeking."
    primaryCta={{ href: "/admissions", label: "See admissions" }}
    secondaryCta={{ href: "/contact", label: "Contact us" }}
  />
</BaseLayout>
