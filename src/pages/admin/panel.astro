---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
import { createSupabaseServerClient } from "../../lib/supabase/server";
import { getActiveMembership } from "../../lib/auth/authorization";
import { getPanelMessages } from "../../lib/panel/data";
import { getClientConfig } from "../../lib/client-config";
import { panelConfig } from "../../config/panel";
import primaryLogo from "../../assets/school/primary/logo-colossalacademy-primary.png";

let authenticated = false;

const supabaseAuth = createSupabaseServerClient(Astro.cookies);

const {
  data: { user },
  error: userError,
} = await supabaseAuth.auth.getUser();

let membership = null;
if (user && !userError) {
  membership = await getActiveMembership({
    userId: user.id,
    siteSlug: panelConfig.siteSlug,
  });

  if (membership) {
    authenticated = true;
  }
}

let clientConfig = null;
let webMessages = [];
let whatsMessages = [];

if (authenticated) {
  clientConfig = await getClientConfig(panelConfig.siteSlug);

  if (clientConfig?.is_active) {
    const result = await getPanelMessages({
      tableWeb: clientConfig.memory_web,
      tableWhats: clientConfig.memory_whats,
    });

    webMessages = result.webMessages;
    whatsMessages = result.whatsMessages;
  }
}

const labels = [];
for (let i = 6; i >= 0; i--) {
  const d = new Date();
  d.setDate(d.getDate() - i);
  labels.push(
    d.toLocaleDateString("es-MX", {
      weekday: "short",
      day: "numeric",
      timeZone: panelConfig.timezone,
    })
  );
}

const cleanJS = (str) => {
  if (!str) return "";
  return str
    .toString()
    .replace(/\r?\n|\r/g, " ")
    .replace(/'/g, "´")
    .replace(/"/g, "´")
    .trim();
};

const processStats = (msgs) => {
  const stats = {};
  labels.forEach((l) => (stats[l] = 0));
  msgs.forEach((m) => {
    const l = new Date(m.created_at).toLocaleDateString("es-MX", {
      weekday: "short",
      day: "numeric",
      timeZone: panelConfig.timezone,
    });
    if (Object.prototype.hasOwnProperty.call(stats, l)) stats[l]++;
  });
  return labels.map((l) => ({ label: l, count: stats[l] }));
};

const webChart = processStats(webMessages);
const whatsChart = processStats(whatsMessages);
const maxVal = Math.max(
  ...webChart.map((d) => d.count),
  ...whatsChart.map((d) => d.count),
  1
);
---

<BaseLayout
  title="Panel admin | Colossal Academy Primary"
  description="Panel protegido de conversaciones y actividad para Colossal Academy Primary."
  currentPath="/admin/panel"
  showSiteChrome={false}
  showChat={false}
>
  <div
    class="min-h-screen bg-[radial-gradient(circle_at_top_left,rgba(109,103,200,0.18),transparent_24%),radial-gradient(circle_at_top_right,rgba(32,187,150,0.14),transparent_18%),linear-gradient(180deg,#f7f6f3_0%,#fdfcfb_28%,#eef4ff_100%)] px-3 py-4 font-sans text-slate-900 md:px-8 md:py-8"
    x-data="panelMetricsState()"
  >
    <div x-show="toastOpen" x-transition x-cloak class="fixed right-3 top-3 z-[60]">
      <div
        class="px-4 py-3 rounded-xl border text-[11px] font-black uppercase tracking-wide shadow-xl"
        :class="toastTone === 'error'
          ? 'bg-red-50 border-red-200 text-red-700'
          : 'bg-white border-[color:var(--color-primary-soft)] text-[color:var(--color-primary)]'"
      >
        <span x-text="toastMessage"></span>
      </div>
    </div>

    <div x-show="modalOpen" class="fixed inset-0 z-50 flex items-center justify-center bg-slate-950/45 p-4 backdrop-blur-sm" x-cloak>
      <div @click.away="modalOpen = false" class="w-full max-w-lg rounded-[2rem] border border-[color:var(--color-primary-soft)] bg-white p-6 shadow-[0_24px_80px_rgba(59,52,131,0.18)]">
        <h3 class="mb-2 text-xs font-black uppercase text-[color:var(--color-primary)]" x-text="mTitle"></h3>
        <p class="text-slate-500 text-[10px] mb-4 font-mono" x-text="mDate"></p>
        <div class="max-h-80 overflow-y-auto rounded-[1.5rem] border border-[color:var(--color-primary-soft)] bg-[color:var(--color-bg-soft)] p-5">
          <p class="text-sm leading-relaxed whitespace-pre-wrap text-slate-700" x-text="mText"></p>
        </div>
        <button
          @click="modalOpen = false"
          class="mt-6 w-full rounded-xl bg-[color:var(--color-primary)] py-4 text-xs font-bold uppercase text-white transition-colors hover:bg-[color:var(--color-secondary)]"
        >
          Cerrar
        </button>
      </div>
    </div>

    {!authenticated ? (
      <div class="flex items-center justify-center py-20 px-4">
        <div class="w-full max-w-md rounded-[2rem] border border-[color:var(--color-primary-soft)] bg-white p-8 shadow-[0_24px_80px_rgba(59,52,131,0.14)]">
          <div class="mb-6 text-center">
            <img src={primaryLogo.src} alt="Colossal Academy Primary" class="mx-auto h-16 w-auto" />
            <p class="mt-5 text-[10px] font-black uppercase tracking-[0.3em] text-[color:var(--color-secondary)]">Colossal Academy Primary</p>
            <h2 class="mt-2 text-2xl font-black tracking-tight text-slate-900">Acceso al panel administrativo</h2>
            <p class="mt-2 text-sm text-slate-600">Ingresa con una cuenta autorizada para revisar conversaciones y actividad reciente.</p>
          </div>

          <form @submit.prevent="submitLogin" class="space-y-4">
            <div x-show="loginError" x-cloak class="mb-4 rounded-xl border border-red-200 bg-red-50 p-4">
              <p class="text-center text-xs font-bold uppercase tracking-tight text-red-700" x-text="loginError"></p>
            </div>

            <input
              x-model="loginEmail"
              type="email"
              name="email"
              placeholder="Email"
              required
              class="w-full rounded-xl border border-[color:var(--color-primary-soft)] bg-[color:var(--color-bg-soft)] px-4 py-3 text-slate-900 outline-none focus:ring-2 focus:ring-[color:var(--color-secondary)]"
            />

            <input
              x-model="loginPassword"
              type="password"
              name="password"
              placeholder="Contraseña"
              required
              class="w-full rounded-xl border border-[color:var(--color-primary-soft)] bg-[color:var(--color-bg-soft)] px-4 py-3 text-slate-900 outline-none focus:ring-2 focus:ring-[color:var(--color-secondary)]"
            />

            <button
              type="submit"
              :disabled="loginLoading"
              :class="loginLoading ? 'opacity-70 cursor-wait' : ''"
              class="w-full rounded-xl bg-[color:var(--color-accent)] py-4 text-xs font-bold uppercase text-white shadow-lg transition-colors hover:bg-[color:var(--color-accent-hover)]"
            >
              <span x-text="loginLoading ? 'Entrando...' : 'Entrar'"></span>
            </button>
          </form>
        </div>
      </div>
    ) : (
      <div class="mx-auto max-w-6xl space-y-6 pb-20">
        <header class="rounded-[2rem] border border-[color:var(--color-primary-soft)] bg-white/90 p-6 shadow-[var(--shadow-card)] backdrop-blur-sm">
          <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
            <div class="flex items-start gap-4">
              <img src={primaryLogo.src} alt="Colossal Academy Primary" class="hidden h-14 w-auto md:block" />
              <div>
                <p class="text-[10px] font-black uppercase tracking-[0.3em] text-[color:var(--color-secondary)]">Colossal Academy Primary</p>
                <h1 class="text-2xl font-black tracking-tight text-slate-900 md:text-3xl">{panelConfig.panelTitle}</h1>
                <p class="mt-1 text-sm text-slate-600">
                  Conversaciones web y WhatsApp de los últimos días para el sitio
                  <span class="font-semibold text-slate-800"> {panelConfig.siteSlug}</span>
                  {user?.email ? <> · Usuario: <span class="font-semibold text-slate-800">{user.email}</span></> : null}
                </p>
              </div>
            </div>

            <div class="flex items-center gap-2 flex-wrap">
            <button
              x-show="filterDay || searchQuery"
              x-transition
              @click="clearFilters()"
              class="rounded-xl border border-red-200 bg-red-50 px-4 py-2 text-[10px] font-black uppercase text-red-700 transition-all hover:bg-red-600 hover:text-white"
            >
              Limpiar filtros
            </button>

            <button
              type="button"
              @click="sendReportEmail()"
              :disabled="reportLoading"
              :class="reportLoading ? 'opacity-70 cursor-wait border-[color:var(--color-primary)] text-[color:var(--color-primary)]' : ''"
              class="grid h-10 w-10 place-items-center rounded-xl border border-[color:var(--color-primary-soft)] bg-[color:var(--color-bg-soft)] text-slate-600 transition-all hover:border-[color:var(--color-primary)] hover:text-[color:var(--color-primary)] md:h-11 md:w-11"
              aria-label="Enviar reporte por email"
              title="Enviar reporte por email"
            >
              <svg x-show="!reportLoading" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
                <path d="M1.5 8.67v8.58a2.25 2.25 0 0 0 2.25 2.25h16.5a2.25 2.25 0 0 0 2.25-2.25V8.67l-8.928 5.493a3.75 3.75 0 0 1-3.144 0L1.5 8.67Z"/>
                <path d="M22.5 6.908v-.158A2.25 2.25 0 0 0 20.25 4.5H3.75A2.25 2.25 0 0 0 1.5 6.75v.158l9.714 5.978a2.25 2.25 0 0 0 1.572 0L22.5 6.908Z"/>
              </svg>
              <svg x-show="reportLoading" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="h-5 w-5 animate-spin">
                <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-opacity=".25" stroke-width="2"></circle>
                <path d="M21 12a9 9 0 0 0-9-9" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
              </svg>
            </button>

            <button
              type="button"
              @click="downloadCsv7d()"
              class="grid h-10 w-10 place-items-center rounded-xl border border-[color:var(--color-primary-soft)] bg-[color:var(--color-bg-soft)] text-slate-600 transition-all hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-accent)] md:h-11 md:w-11"
              aria-label="Descargar CSV"
              title="Descargar CSV 7 días"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
                <path d="M12 16.5a.75.75 0 0 0 .53-.22l3.75-3.75a.75.75 0 1 0-1.06-1.06l-2.47 2.47V4.5a.75.75 0 0 0-1.5 0v9.44l-2.47-2.47a.75.75 0 1 0-1.06 1.06l3.75 3.75A.75.75 0 0 0 12 16.5Z"/>
                <path d="M3.75 15a.75.75 0 0 0-.75.75v2.5A2.75 2.75 0 0 0 5.75 21h12.5A2.75 2.75 0 0 0 21 18.25v-2.5a.75.75 0 0 0-1.5 0v2.5c0 .69-.56 1.25-1.25 1.25H5.75c-.69 0-1.25-.56-1.25-1.25v-2.5a.75.75 0 0 0-.75-.75Z"/>
              </svg>
            </button>

            <button
              type="button"
              @click="logout()"
              class="grid h-10 w-10 place-items-center rounded-xl border border-[color:var(--color-primary-soft)] bg-[color:var(--color-bg-soft)] text-slate-600 transition-all hover:border-rose-300 hover:text-rose-600 md:h-11 md:w-11"
              aria-label="Salir"
              title="Salir"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
                <path fill-rule="evenodd" d="M7.5 3.75A2.25 2.25 0 0 0 5.25 6v12A2.25 2.25 0 0 0 7.5 20.25h4.5a.75.75 0 0 0 0-1.5H7.5A.75.75 0 0 1 6.75 18V6A.75.75 0 0 1 7.5 5.25H12a.75.75 0 0 0 0-1.5H7.5Z" clip-rule="evenodd"/>
                <path fill-rule="evenodd" d="M12.97 8.47a.75.75 0 0 1 1.06 0l3 3a.75.75 0 0 1 0 1.06l-3 3a.75.75 0 1 1-1.06-1.06l1.72-1.72H9a.75.75 0 0 1 0-1.5h5.69l-1.72-1.72a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/>
              </svg>
            </button>

            <p x-show="reportStatusText" x-text="reportStatusText" class="ml-1 text-[10px] font-bold uppercase tracking-wide text-[color:var(--color-primary)]"></p>
            </div>
          </div>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="rounded-[2rem] border border-[color:var(--color-primary-soft)] bg-white/90 p-5 shadow-[var(--shadow-card)]">
            <h3 class="mb-8 text-[10px] font-black uppercase tracking-widest text-[color:var(--color-primary)]">Web (Actividad)</h3>
            <div class="flex items-end gap-2 h-24">
              {webChart.map((d) => (
                <button
                  @click={`filterDay = (filterDay === '${d.label}' ? '' : '${d.label}'); tab = 'web'`}
                  class="flex-1 rounded-t-lg relative transition-all duration-300"
                  style={`height: ${(d.count / maxVal) * 100}%; background-color: rgba(109, 103, 200, 0.18)`}
                  :class={`filterDay === '${d.label}' ? '!bg-[color:var(--color-primary)] shadow-lg' : ''`}
                >
                  <span class="absolute -top-6 w-full text-center text-[9px] font-black text-[color:var(--color-primary)]">{d.count}</span>
                  <div class="absolute bottom-[-22px] w-full text-center text-[8px] font-bold text-slate-500 uppercase">{d.label}</div>
                </button>
              ))}
            </div>
          </div>

          <div class="rounded-[2rem] border border-[color:var(--color-primary-soft)] bg-white/90 p-5 shadow-[var(--shadow-card)]">
            <h3 class="mb-8 text-[10px] font-black uppercase tracking-widest text-[color:var(--color-accent)]">WhatsApp (Actividad)</h3>
            <div class="flex items-end gap-2 h-24">
              {whatsChart.map((d) => (
                <button
                  @click={`filterDay = (filterDay === '${d.label}' ? '' : '${d.label}'); tab = 'whats'`}
                  class="flex-1 rounded-t-lg relative transition-all duration-300"
                  style={`height: ${(d.count / maxVal) * 100}%; background-color: rgba(52, 211, 153, 0.18)`}
                  :class={`filterDay === '${d.label}' ? '!bg-[color:var(--color-accent)] shadow-lg' : ''`}
                >
                  <span class="absolute -top-6 w-full text-center text-[9px] font-black text-[color:var(--color-accent)]">{d.count}</span>
                  <div class="absolute bottom-[-22px] w-full text-center text-[8px] font-bold text-slate-500 uppercase">{d.label}</div>
                </button>
              ))}
            </div>
          </div>
        </div>

        <div class="flex flex-col md:flex-row items-center justify-between gap-4 px-2 pt-4">
          <div class="flex gap-2 rounded-2xl border border-[color:var(--color-primary-soft)] bg-white/90 p-1 shadow-[var(--shadow-card)]">
            <button @click="tab = 'web'" :class="tab === 'web' ? 'bg-[color:var(--color-primary)] text-white' : 'text-slate-500'" class="px-6 py-2 rounded-xl text-[10px] font-black uppercase transition-all">Web</button>
            <button @click="tab = 'whats'" :class="tab === 'whats' ? 'bg-[color:var(--color-accent)] text-white' : 'text-slate-500'" class="px-6 py-2 rounded-xl text-[10px] font-black uppercase transition-all">WhatsApp</button>
          </div>

          <div class="relative w-full md:w-80">
            <input
              x-model="searchQuery"
              type="text"
              placeholder="Buscar por texto..."
              class="w-full rounded-xl border border-[color:var(--color-primary-soft)] bg-white/90 px-4 py-3 text-xs text-slate-900 outline-none focus:ring-1 focus:ring-[color:var(--color-primary)]"
            />
            <button x-show="searchQuery" @click="searchQuery = ''" class="absolute right-3 top-2.5 text-lg text-slate-500 hover:text-slate-900">×</button>
          </div>
        </div>

        <div class="overflow-hidden rounded-[2rem] border border-[color:var(--color-primary-soft)] bg-white/95 shadow-[0_24px_80px_rgba(59,52,131,0.12)]">
          <div x-show="tab === 'web'">
            <table class="w-full text-left table-fixed">
              <thead class="border-b border-[color:var(--color-primary-soft)] bg-[color:var(--color-bg-soft)] text-[10px] uppercase tracking-widest text-slate-500">
                <tr>
                  <th class="px-4 py-4 w-20">Fecha</th>
                  <th class="px-4 py-4">Mensaje Web</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-[color:var(--color-primary-soft)]">
                {webMessages.map((m) => {
                  const originalTxt = m.message?.text || m.message?.content || "";
                  const safeTxt = cleanJS(originalTxt);
                  const label = new Date(m.created_at).toLocaleDateString("es-MX", {
                    weekday: "short",
                    day: "numeric",
                    timeZone: panelConfig.timezone,
                  });
                  const displayDate = new Date(m.created_at).toLocaleString("es-MX", {
                    timeZone: panelConfig.timezone,
                  });

                  return (
                    <tr
                      x-show={`(filterDay === '' || filterDay === '${label}') && ('${safeTxt.toLowerCase()}'.includes(searchQuery.toLowerCase()))`}
                      class="cursor-pointer transition-colors hover:bg-[rgba(109,103,200,0.08)]"
                      @click={`openModal('MENSAJE WEB', '${safeTxt}', '${displayDate}')`}
                    >
                      <td class="px-4 py-2 leading-none">
                        <div class="text-[10px] font-black text-[color:var(--color-primary)]">
                          {new Date(m.created_at).toLocaleDateString("es-MX", {
                            day: "2-digit",
                            month: "2-digit",
                            timeZone: panelConfig.timezone,
                          })}
                        </div>
                        <div class="text-[9px] opacity-40 font-mono">
                          {new Date(m.created_at).toLocaleTimeString("es-MX", {
                            hour: "2-digit",
                            minute: "2-digit",
                            timeZone: panelConfig.timezone,
                          })}
                        </div>
                      </td>
                      <td class="truncate px-4 py-2 text-xs text-slate-700">{originalTxt}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>

          <div x-show="tab === 'whats'">
            <table class="w-full text-left table-fixed">
              <thead class="border-b border-[color:var(--color-primary-soft)] bg-[color:var(--color-bg-soft)] text-[10px] uppercase tracking-widest text-slate-500">
                <tr>
                  <th class="px-4 py-4 w-20">Fecha</th>
                  <th class="px-4 py-4 w-32">WhatsApp</th>
                  <th class="px-4 py-4">Mensaje</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-[color:var(--color-primary-soft)]">
                {whatsMessages.map((m) => {
                  const originalTxt = m.message?.text || m.message?.content || "";
                  const safeTxt = cleanJS(originalTxt);
                  const phone = (m.session_id || "").replace("whatsapp:", "").split("@")[0];
                  const label = new Date(m.created_at).toLocaleDateString("es-MX", {
                    weekday: "short",
                    day: "numeric",
                    timeZone: panelConfig.timezone,
                  });
                  const displayDate = new Date(m.created_at).toLocaleString("es-MX", {
                    timeZone: panelConfig.timezone,
                  });

                  return (
                    <tr
                      x-show={`(filterDay === '' || filterDay === '${label}') && ('${safeTxt.toLowerCase()}'.includes(searchQuery.toLowerCase()) || '${phone}'.includes(searchQuery))`}
                      class="cursor-pointer transition-colors hover:bg-[rgba(32,187,150,0.08)]"
                      @click={`openModal('WA: ${phone}', '${safeTxt}', '${displayDate}')`}
                    >
                      <td class="px-4 py-2 leading-none">
                        <div class="text-[10px] font-black text-[color:var(--color-accent)]">
                          {new Date(m.created_at).toLocaleDateString("es-MX", {
                            day: "2-digit",
                            month: "2-digit",
                            timeZone: panelConfig.timezone,
                          })}
                        </div>
                        <div class="text-[9px] opacity-40 font-mono">
                          {new Date(m.created_at).toLocaleTimeString("es-MX", {
                            hour: "2-digit",
                            minute: "2-digit",
                            timeZone: panelConfig.timezone,
                          })}
                        </div>
                      </td>
                      <td class="px-4 py-2">
                        <div class="text-[11px] font-black tracking-tight text-slate-800">+{phone}</div>
                      </td>
                      <td class="truncate px-4 py-2 text-xs text-slate-700">{originalTxt}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  [x-cloak] { display: none !important; }
</style>

<script is:inline define:vars={{ webMessages, whatsMessages }}>
  window.panelMetricsState = function () {
    return {
      loginEmail: '',
      loginPassword: '',
      loginError: '',
      loginLoading: false,
      tab: 'whats',
      filterDay: '',
      searchQuery: '',
      modalOpen: false,
      mTitle: '',
      mText: '',
      mDate: '',
      reportLoading: false,
      reportStatusText: '',
      toastOpen: false,
      toastMessage: '',
      toastTone: 'ok',
      toastTimer: null,
      webData: Array.isArray(webMessages) ? webMessages : [],
      whatsData: Array.isArray(whatsMessages) ? whatsMessages : [],

      openModal(title, text, date) {
        this.mTitle = title;
        this.mText = text;
        this.mDate = date;
        this.modalOpen = true;
      },

      showToast(message, tone) {
        this.toastMessage = message;
        this.toastTone = tone || 'ok';
        this.toastOpen = true;
        if (this.toastTimer) clearTimeout(this.toastTimer);
        this.toastTimer = setTimeout(() => {
          this.toastOpen = false;
        }, 2800);
      },

      async sendReportEmail() {
        if (this.reportLoading) return;

        this.reportLoading = true;
        this.reportStatusText = 'Enviando reporte...';

        try {
          const res = await fetch('/api/send-report', {
            method: 'POST'
          });

          const data = await res.json();

          if (!res.ok || !data.ok) {
            this.showToast(data.message || 'Error al enviar reporte', 'error');
            this.reportStatusText = 'Error';
            return;
          }

          this.showToast('Reporte enviado', 'ok');
          this.reportStatusText = 'Enviado';
        } catch (error) {
          console.error(error);
          this.showToast('Error de red', 'error');
          this.reportStatusText = 'Error';
        } finally {
          this.reportLoading = false;
          setTimeout(() => {
            this.reportStatusText = '';
          }, 3000);
        }
      },

      async logout() {
        try {
          const res = await fetch('/api/logout', {
            method: 'POST'
          });

          const data = await res.json();

          if (!res.ok || !data.ok) {
            this.showToast(data.message || 'No se pudo cerrar sesión', 'error');
            return;
          }

          window.location.reload();
        } catch (error) {
          console.error('logout error:', error);
          this.showToast('Error de red al cerrar sesión', 'error');
        }
      },

      downloadCsv7d() {
        const sevenDaysAgo = new Date();
        sevenDaysAgo.setHours(0, 0, 0, 0);
        sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 6);

        const toRecord = (channel, item) => {
          const rawMessage = item && item.message ? item.message : {};
          const rawText = rawMessage.text || rawMessage.content || '';
          const sessionId = item && item.session_id ? item.session_id : '';
          const phone = channel === 'whatsapp'
            ? sessionId.replace('whatsapp:', '').split('@')[0]
            : '';

          return {
            channel,
            created_at: item && item.created_at ? item.created_at : '',
            phone,
            message: String(rawText).replace(/\r?\n|\r/g, ' ').trim()
          };
        };

        const allRows = []
          .concat(this.webData.map((item) => toRecord('web', item)))
          .concat(this.whatsData.map((item) => toRecord('whatsapp', item)))
          .filter((row) => row.created_at && new Date(row.created_at) >= sevenDaysAgo);

        const doubleQuote = '"';
        const quoteRegex = /"/g;
        const escapeCsv = (value) => doubleQuote + String(value || '').replace(quoteRegex, '""') + doubleQuote;
        const csvLines = [
          ['channel', 'created_at', 'phone', 'message'].map(escapeCsv).join(','),
          ...allRows.map((row) =>
            [row.channel, row.created_at, row.phone, row.message].map(escapeCsv).join(',')
          )
        ];

        const blob = new Blob([csvLines.join('\n')], { type: 'text/csv;charset=utf-8;' });
        const url = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = url;
        link.download = `${'mente'}-panel-7d-${new Date().toISOString().slice(0, 10)}.csv`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        URL.revokeObjectURL(url);
      },

      clearFilters() {
        this.searchQuery = '';
        this.filterDay = '';
      },

      async submitLogin() {
        if (this.loginLoading) return;

        this.loginError = '';

        if (!this.loginEmail || !this.loginPassword) {
          this.loginError = 'Email y contraseña son obligatorios';
          return;
        }

        this.loginLoading = true;

        try {
          const res = await fetch('/api/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              email: this.loginEmail,
              password: this.loginPassword
            })
          });

          const data = await res.json();

          if (!res.ok || !data.ok) {
            this.loginError = data.message || 'No se pudo iniciar sesión';
            return;
          }

          window.location.reload();
        } catch (error) {
          console.error('Error de login:', error);
          this.loginError = 'Error de red al iniciar sesión';
        } finally {
          this.loginLoading = false;
        }
      },
    };
  };
</script>

