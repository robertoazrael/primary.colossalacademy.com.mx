---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTASection from "../components/CTASection.astro";
import FeatureCard from "../components/FeatureCard.astro";
import Hero from "../components/Hero.astro";
import SectionIntro from "../components/SectionIntro.astro";

const supportAreas = [
  {
    title: "Appropriate academic stretch",
    description:
      "We respond when students show readiness for greater depth, abstraction, and complexity rather than keeping everyone on the same path."
  },
  {
    title: "Flexible pathways",
    description:
      "Children may move into richer tasks, advanced texts, independent investigations, or more sophisticated products as needed."
  },
  {
    title: "Social and emotional understanding",
    description:
      "Giftedness can come with intensity, sensitivity, perfectionism, or asynchronous development. We plan with those realities in mind."
  }
];

const practices = [
  {
    title: "Pre-assessment and observation",
    description:
      "Teachers look carefully at what a child already knows so instruction can begin from readiness rather than assumption."
  },
  {
    title: "Depth, not simply more",
    description:
      "Challenge means richer thinking, stronger questions, and better problems to solve, not just an increased volume of work."
  },
  {
    title: "Project-based opportunities",
    description:
      "Students can pursue extended inquiries that call for synthesis, creativity, and ownership."
  },
  {
    title: "Mentorship and feedback",
    description:
      "Children benefit from adults who can notice strengths, guide habits, and coach them through moments of frustration or underchallenge."
  }
];

const familyNotes = [
  {
    title: "Families know their child best",
    description:
      "We value close communication with parents and use it to understand learner profiles, interests, and needs."
  },
  {
    title: "Fit matters",
    description:
      "A gifted learner often thrives when challenge, emotional safety, and teacher understanding are present together."
  },
  {
    title: "Growth is individual",
    description:
      "No single profile defines an advanced learner. Our role is to notice and respond thoughtfully."
  }
];
---

<BaseLayout
  title="Gifted Learning | Primary Colossal Academy"
  description="How Primary Colossal Academy supports gifted and advanced learners through challenge, personalization, and thoughtful mentorship."
  currentPath="/gifted-learning"
>
  <Hero
    eyebrow="Gifted and advanced learners"
    title="A school experience that respects"
    highlight="depth, intensity, and potential."
    description="Some children need more complexity, more autonomy, and more meaningful intellectual challenge. Our approach is designed to recognize that early and respond with care."
    primaryCta={{ href: "/contact", label: "Talk with admissions" }}
    secondaryCta={{ href: "/approach", label: "Read about our approach" }}
    imageSrc="/images/hero-learning.svg"
    imageAlt="Illustrated children reading and discussing ideas"
  />

  <section class="section-spacing pt-8">
    <div class="container space-y-10">
      <SectionIntro
        eyebrow="What support looks like"
        title="We move beyond one-size-fits-all instruction"
        description="Gifted education is not only about acceleration. It is also about intellectual fit, emotional understanding, and giving bright children work worthy of their attention."
      />
      <div class="grid gap-6 md:grid-cols-3">
        {supportAreas.map((item) => <FeatureCard {...item} />)}
      </div>
    </div>
  </section>

  <section class="section-spacing bg-white">
    <div class="container space-y-10">
      <SectionIntro
        eyebrow="Core practices"
        title="How teachers respond to advanced readiness"
        description="Our classrooms use flexible structures that make personalized challenge possible without losing warmth or continuity."
      />
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
        {practices.map((item) => <FeatureCard {...item} />)}
      </div>
    </div>
  </section>

  <section class="section-spacing">
    <div class="container space-y-10">
      <SectionIntro
        eyebrow="Partnership with families"
        title="A thoughtful conversation around each child"
        description="Families are central partners in understanding how a student learns, what excites them, and where they may need extra support."
      />
      <div class="grid gap-6 md:grid-cols-3">
        {familyNotes.map((item) => <FeatureCard {...item} />)}
      </div>
    </div>
  </section>

  <CTASection
    title="If your child needs deeper challenge, we would value the conversation."
    description="We are happy to talk with families about learner profiles, readiness, and what a strong primary-school fit can look like."
    primaryCta={{ href: "/contact", label: "Contact the school" }}
    secondaryCta={{ href: "/admissions", label: "Admissions process" }}
  />
</BaseLayout>
